# =============================================================================
# Crooked Finger Backend — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://crochet_user:your_password@localhost:5433/crooked_finger_db

# --- Authentication & Security ---
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_SECRET=change-me-to-a-random-secret

# --- AI Services ---
# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# OpenRouter for free fallback models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# --- External APIs ---
# RapidAPI key for YouTube transcript extraction (https://rapidapi.com)
RAPIDAPI_KEY=
# Optional HTTP proxy for YouTube requests
# YOUTUBE_PROXY_URL=

# --- Application ---
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
